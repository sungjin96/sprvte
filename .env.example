# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_assets_maker

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Provider Config
PROVIDER_IMAGE=replicate
PROVIDER_AUDIO=mubert
PROVIDER_ANIMATION=autosprite

# Replicate API
REPLICATE_API_TOKEN=your_replicate_api_token

# Mubert API
MUBERT_API_KEY=your_mubert_api_key

# AutoSprite API
AUTOSPRITE_API_KEY=your_autosprite_api_key

# Storage (Phase 1: local filesystem)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# Remove.bg API (fallback for rembg)
REMOVEBG_API_KEY=your_removebg_api_key
