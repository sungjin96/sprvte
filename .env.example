# =============================================================================
# Spryte v5 environment template — copy to .env.local and fill in.
# Anything starting with NEXT_PUBLIC_ is exposed to the browser bundle.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
# Publishable key (sb_publishable_*) — safe in browser, RLS gates all access
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret key (sb_secret_*) — server-only, RLS-bypassing, never commit
SUPABASE_SECRET_KEY=sb_secret_...

# Database connection strings (Supabase Dashboard → Database → Connection string)
# Pooled (port 6543) — used by app runtime
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
# Direct (port 5432) — used by drizzle migrations only
DATABASE_DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ── Redis (BullMQ worker queue) ──────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Prod: Upstash https://upstash.com (free tier 10k commands/day)
REDIS_URL=redis://localhost:6379

# ── Stripe (S5) ──────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys (use test mode keys until launch)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Generated when you create a webhook endpoint in Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI Provider keys (server-only) ───────────────────────────────────────────
# Replicate: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...
# OpenAI (for GPT-Image-2): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Mubert (BGM)
MUBERT_API_KEY=
# ElevenLabs (SFX)
ELEVENLABS_API_KEY=
# Stability Audio (premium audio — replaces Suno)
STABILITY_API_KEY=

# ── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
